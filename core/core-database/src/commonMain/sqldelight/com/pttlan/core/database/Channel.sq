import kotlin.Boolean;

CREATE TABLE Channel (
    id TEXT NOT NULL PRIMARY KEY,
    name TEXT NOT NULL,
    lastJoinedAt INTEGER NOT NULL,
    isFavorite INTEGER AS Boolean NOT NULL DEFAULT 0
);

selectAllChannels:
SELECT * FROM Channel ORDER BY lastJoinedAt DESC;

insertOrReplaceChannel:
INSERT OR REPLACE INTO Channel(id, name, lastJoinedAt, isFavorite)
VALUES (?, ?, ?, ?);
